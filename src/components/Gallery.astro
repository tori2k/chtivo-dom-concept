---
const base = import.meta.env.BASE_URL;
const photos = [
  { src: 'hero-interior.jpg', span: 'big', caption: 'Главный зал с&nbsp;флагом' },
  { src: 'cafe-bar.jpg', span: 'wide', caption: 'Кухня' },
  { src: 'bar-menu.jpg', span: 'tall', caption: 'Барная карта' },
  { src: 'hall-wide.jpg', span: 'wide', caption: 'Гостиная' },
  { src: 'hall-2.jpg', span: 'normal', caption: 'Общая зона' },
  { src: 'hall-3.jpg', span: 'normal', caption: 'Со&nbsp;второго этажа' },
];
---
<section class="gallery">
  <div class="container-x">
    <div class="gallery__head reveal">
      <div class="sec-tag">Интерьер</div>
      <h2 class="display-h">
        Реставрированный<br/>
        <em>Дом культуры</em>
      </h2>
      <p class="gallery__lead">
        Построено в&nbsp;здании Музея Москвы на&nbsp;базе бывшего кинотеатра «Москино Музейный»: кирпич, дерево, стальные балки. Большая ламельная крыша над&nbsp;баром — выглядит как театральная декорация.
      </p>
    </div>

    <div class="gallery__grid">
      {photos.map((p, i) => (
        <figure class:list={['gcard', `gcard--${p.span}`, 'reveal']} style={`transition-delay: ${i * 0.06}s`}>
          <img src={`${base}/media/${p.src}`} alt="" loading="lazy" decoding="async" />
          <figcaption set:html={p.caption}></figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery { padding: 160px 0; }
  .gallery__head {
    max-width: 860px;
    margin-bottom: 60px;
  }
  .gallery__lead {
    font-family: var(--font-sans);
    font-size: clamp(15px, 1.3vw, 18px);
    line-height: 1.6;
    color: var(--color-text-soft);
    margin: 32px 0 0;
    max-width: 640px;
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 220px;
    gap: 14px;
  }
  .gcard {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    margin: 0;
  }
  .gcard img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1s cubic-bezier(.22,1,.36,1);
  }
  .gcard:hover img { transform: scale(1.04); }
  .gcard figcaption {
    position: absolute;
    bottom: 14px;
    left: 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-bg);
    padding: 5px 10px;
    background: rgba(20,18,16,0.75);
    backdrop-filter: blur(4px);
  }
  .gcard--big { grid-column: span 2; grid-row: span 2; }
  .gcard--wide { grid-column: span 2; }
  .gcard--tall { grid-row: span 2; }
  .gcard--normal { grid-column: span 1; }

  @media (max-width: 1000px) {
    .gallery__grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 200px; }
    .gcard--big { grid-column: span 2; grid-row: span 2; }
    .gcard--wide { grid-column: span 2; grid-row: span 1; }
    .gcard--tall { grid-column: span 1; grid-row: span 2; }
  }
  @media (max-width: 600px) {
    .gallery { padding: 80px 0; }
    .gallery__grid { grid-template-columns: 1fr; grid-auto-rows: 260px; }
    .gcard--big, .gcard--wide, .gcard--tall, .gcard--normal {
      grid-column: span 1; grid-row: span 1;
    }
    .gcard--big { grid-row: span 2; }
  }
</style>
