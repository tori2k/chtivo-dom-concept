---
const base = import.meta.env.BASE_URL;

const bar = [
  { name: 'Американо', size: '200 / 300 мл', price: '250 / 280 ₽' },
  { name: 'Капучино', size: '300 мл', price: '380 ₽' },
  { name: 'Латте', size: '300 мл', price: '350 ₽' },
  { name: 'Матча-латте', size: '300 мл', price: '310 ₽' },
  { name: 'Раф', size: '300 мл', price: '270 ₽' },
  { name: 'Эспрессо-тоник', size: '300 мл', price: '410 ₽' },
  { name: 'Хамовники венское', size: '0,5 л', price: '450 ₽', category: 'Бар' },
  { name: 'Сидр «Сидорова коза»', size: '0,5 л', price: '450 ₽', category: 'Бар' },
];
---
<section class="kitchen" id="kitchen">
  <div class="container-x">
    <div class="kitchen__head reveal">
      <div class="sec-tag">Кухня · Бар</div>
      <h2 class="display-h kitchen__title">
        Полукилограммовые<br/>
        <em>сэндвичи</em><br/>
        с&nbsp;мортаделлой
      </h2>
    </div>

    <div class="kitchen__grid">
      <!-- Left: big dodgy photo -->
      <div class="kitchen__hero reveal-left" data-parallax="0.04">
        <img src={`${base}/media/sandwich.jpg`} alt="Сэндвич Dodgy на тарелке Чтиво" loading="lazy" />
        <span class="kitchen__hero-badge">DODGY × ЧТИВО ДОМ</span>
      </div>

      <!-- Right: second photo + description -->
      <div class="kitchen__side reveal-right">
        <p class="kitchen__lead">
          Друзья из&nbsp;<b>Dodgy</b> — те&nbsp;самые, которые прославились на&nbsp;всю Москву своими сэндвичами, — готовят на&nbsp;кухне ЧТИВО ДОМА завтраки, обеды и&nbsp;ужины. Хлеб свой, мортаделла честная, картошка сладкая.
        </p>
        <div class="kitchen__photo">
          <img src={`${base}/media/dodgy.jpg`} alt="Сэндвич Dodgy и картошка" loading="lazy" />
        </div>
      </div>
    </div>

    <!-- Bar card -->
    <div class="bar reveal">
      <div class="bar__head">
        <div class="bar__title-group">
          <div class="room-label">/ меню · bar</div>
          <h3 class="bar__title">Что пьём</h3>
        </div>
        <div class="bar__note">Барная стойка открыта весь день, кофе — с&nbsp;9:00</div>
      </div>

      <div class="bar__list">
        {bar.map((b) => (
          <div class="bar__row">
            <div class="bar__name">{b.name}</div>
            <div class="bar__size">{b.size}</div>
            <div class="bar__dots" aria-hidden="true"></div>
            <div class="bar__price">{b.price}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .kitchen { padding: 160px 0; }
  .kitchen__head {
    max-width: 900px;
    margin-bottom: 60px;
  }
  .kitchen__title { margin: 0; }

  .kitchen__grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 40px;
    align-items: stretch;
    margin-bottom: 80px;
  }
  .kitchen__hero {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--color-surface);
  }
  .kitchen__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(.22,1,.36,1);
  }
  .kitchen__hero:hover img { transform: scale(1.03); }
  .kitchen__hero-badge {
    position: absolute;
    top: 20px;
    left: 20px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-bg);
    padding: 8px 14px;
    background: var(--color-brand);
  }

  .kitchen__side {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .kitchen__lead {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(22px, 2vw, 30px);
    line-height: 1.25;
    color: var(--color-text);
    margin: 0;
    text-transform: none;
    letter-spacing: -0.01em;
  }
  .kitchen__lead b {
    color: var(--color-brand);
    font-weight: 400;
  }
  .kitchen__photo {
    aspect-ratio: 1/1;
    overflow: hidden;
    background: var(--color-surface);
    flex: 1;
  }
  .kitchen__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Bar */
  .bar {
    border-top: 1.5px solid var(--color-text);
    border-bottom: 1.5px solid var(--color-text);
    padding: 40px 0;
  }
  .bar__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 32px;
  }
  .bar__title {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 72px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 6px 0 0;
    color: var(--color-brand);
    text-transform: uppercase;
  }
  .bar__note {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--color-muted);
    max-width: 300px;
    text-align: right;
  }

  .bar__list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .bar__row {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto;
    gap: 16px;
    align-items: baseline;
  }
  .bar__name {
    font-family: var(--font-display);
    font-size: clamp(20px, 1.8vw, 26px);
    font-weight: 400;
    letter-spacing: -0.005em;
    color: var(--color-text);
    text-transform: uppercase;
  }
  .bar__size {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 1px;
    color: var(--color-muted);
  }
  .bar__dots {
    height: 1px;
    background-image: repeating-linear-gradient(90deg, var(--color-border-2) 0 4px, transparent 4px 10px);
    align-self: center;
    min-width: 20px;
  }
  .bar__price {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--color-brand);
    text-align: right;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .kitchen { padding: 80px 0; }
    .kitchen__grid { grid-template-columns: 1fr; gap: 28px; margin-bottom: 56px; }
    .bar__head { flex-direction: column; align-items: flex-start; }
    .bar__note { text-align: left; }
    .bar__row {
      grid-template-columns: 1fr auto;
      gap: 4px 16px;
    }
    .bar__size {
      grid-column: 1;
      grid-row: 2;
      font-size: 11px;
    }
    .bar__dots { display: none; }
    .bar__price {
      grid-column: 2;
      grid-row: 1 / 3;
      align-self: center;
    }
  }
</style>
