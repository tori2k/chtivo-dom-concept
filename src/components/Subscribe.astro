---
const channels = [
  { n: '01', label: 'Telegram', sub: '@chtvmag', icon: 'tg' },
  { n: '02', label: 'Email-рассылка', sub: 'раз в месяц', icon: 'mail' },
  { n: '03', label: 'WhatsApp', sub: 'канал', icon: 'wa' },
  { n: '04', label: 'ВКонтакте', sub: 'vk.com/chtivomag', icon: 'vk' },
];

const iconPaths: Record<string, string> = {
  tg: '<path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="1" stroke="currentColor" stroke-width="1.6"/><path d="M3 7l9 6 9-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
  wa: '<path d="M21 11.5a8.4 8.4 0 01-12.5 7.3L3 21l1.9-5.7A8.4 8.4 0 1121 11.5z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
  vk: '<path d="M5 7h2.5c.4 4 2 7 3.5 7V7H13v4c1.5 0 3-2 3.5-4H19c-.5 2.5-2 5-3.5 6 1.5 1 3 3.5 3.5 5h-2.5C16 16 14.5 14 13 14v3h-1.5c-3 0-6-3-6.5-10z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>',
};
---
<section class="sub" id="subscribe" aria-labelledby="sub-title">
  <div class="container-x sub__inner">
    <!-- Левая колонка: типографика как в журнале -->
    <div class="sub__left">
      <div class="sub__eyebrow reveal">
        <span class="sub__eyebrow-dot"></span>
        <span class="sub__eyebrow-text">ПОДПИСКА · TOM № <em id="sub-vol">14</em></span>
        <span class="sub__eyebrow-line"></span>
      </div>

      <h2 id="sub-title" class="sub__title">
        <span class="sub__word">НЕ&nbsp;ПРОПУСТИ</span>
        <span class="sub__word sub__word--serif">
          <em>новый</em>
        </span>
        <span class="sub__word sub__word--accent">НОМЕР</span>
      </h2>

      <p class="sub__lead reveal">
        Журнал выходит раз в&nbsp;два месяца. Истории и&nbsp;теории, факты и&nbsp;легенды,
        люди и&nbsp;страны&nbsp;— в&nbsp;шутку и&nbsp;серьёзно. Подпишитесь и&nbsp;узнавайте
        о&nbsp;каждом новом томе первыми.
      </p>

      <!-- Форма-«типографская строка» -->
      <form class="sub__form reveal" data-stagger novalidate>
        <label class="sub__field" for="sub-email">
          <span class="sub__field-label">Ваш e-mail</span>
          <input
            id="sub-email"
            type="email"
            inputmode="email"
            autocomplete="email"
            placeholder="ivan@example.ru"
            required
          />
          <span class="sub__field-cursor" aria-hidden="true"></span>
        </label>

        <button type="submit" class="sub__submit">
          <span class="sub__submit-text">Подписаться</span>
          <span class="sub__submit-stamp" aria-hidden="true">
            <span class="sub__stamp-inner">
              <span class="sub__stamp-ring">
                <span>ЧТИВО · ЧТИВО · ЧТИВО · ЧТИВО · </span>
              </span>
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" aria-hidden="true">
                <path d="M5 12l5 5L20 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </span>
        </button>

        <p class="sub__consent">
          Нажимая «Подписаться», вы&nbsp;соглашаетесь получать
          письма о&nbsp;новых номерах. Можно отписаться в&nbsp;один клик.
        </p>
      </form>

      <!-- Чипсы каналов -->
      <div class="sub__channels reveal" data-stagger>
        <span class="sub__channels-label">— или&nbsp;следите за&nbsp;выходом:</span>
        <ul class="sub__channels-list">
          {channels.map((c) => (
            <li class="sub__channel reveal">
              <span class="sub__channel-n">N°{c.n}</span>
              <span class="sub__channel-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" set:html={iconPaths[c.icon]}></svg>
              </span>
              <span class="sub__channel-body">
                <span class="sub__channel-label">{c.label}</span>
                <span class="sub__channel-sub">{c.sub}</span>
              </span>
              <span class="sub__channel-arrow">→</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Правая колонка: «обложка журнала» -->
    <div class="sub__right" aria-hidden="true">
      <div class="sub__mag" data-mag>
        <div class="sub__mag-cover">
          <div class="sub__mag-paper"></div>
          <div class="sub__mag-spine"></div>

          <div class="sub__mag-top">
            <span class="sub__mag-issn">ISSN 2949-XXXX</span>
            <span class="sub__mag-date">№ 14 · 2026</span>
          </div>

          <div class="sub__mag-brand">
            <span class="sub__mag-brand-serif">Ч</span>
            <span class="sub__mag-brand-stack">
              <span>ЧТИВО</span>
              <span class="sub__mag-brand-tag">Журнал · Том&nbsp;14</span>
            </span>
          </div>

          <div class="sub__mag-headline">
            <span>«В чём смысл&nbsp;— знают только те, кто его&nbsp;ищет»</span>
          </div>

          <div class="sub__mag-rubrics">
            <span>· Безумная история</span>
            <span>· Большие деньги</span>
            <span>· Один кадр</span>
            <span>· Среда обитания</span>
          </div>

          <div class="sub__mag-bottom">
            <span>Авторский проект</span>
            <span>Сергея&nbsp;Минаева</span>
          </div>
        </div>

        <!-- Sticker «NEW» -->
        <span class="sub__sticker">
          <span>NEW</span>
          <span>·</span>
          <span>2026</span>
        </span>
      </div>

      <!-- Декоративные подписи на полях -->
      <div class="sub__margin sub__margin--1">→ доставка по&nbsp;всей России</div>
      <div class="sub__margin sub__margin--2">↘ цифровая версия в&nbsp;день&nbsp;выхода</div>
    </div>
  </div>
</section>

<style>
  .sub {
    position: relative;
    padding: 120px 0 120px;
    background: var(--color-bg);
    overflow: hidden;
  }
  /* Бумага в линейку как у тетради/типографа */
  .sub::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, transparent 0, transparent 31px, rgba(20,18,16,0.05) 31px, rgba(20,18,16,0.05) 32px);
    pointer-events: none;
    opacity: 0.55;
  }
  .sub::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(60% 50% at 80% 0%, rgba(222,57,34,0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .sub__inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: 80px;
    align-items: center;
  }

  /* ─── Eyebrow «ПОДПИСКА · ТОМ № 14» ──────────────────────────── */
  .sub__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--color-muted);
    text-transform: uppercase;
    margin-bottom: 28px;
  }
  .sub__eyebrow-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-brand);
    animation: subPulse 2s ease-in-out infinite;
  }
  .sub__eyebrow-text em {
    font-style: normal;
    color: var(--color-text);
    font-weight: 700;
    margin-left: 4px;
    display: inline-block;
    min-width: 2ch;
    text-align: right;
  }
  .sub__eyebrow-line {
    flex: 0 0 64px;
    height: 1px;
    background: currentColor;
    opacity: 0.4;
  }
  @keyframes subPulse {
    0%,100% { transform: scale(1); opacity: 1; }
    50%     { transform: scale(1.4); opacity: 0.6; }
  }

  /* ─── Большой заголовок ──────────────────────────────────────── */
  .sub__title {
    margin: 0 0 28px;
    display: flex;
    flex-direction: column;
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 0.86;
    letter-spacing: -0.005em;
    font-size: clamp(58px, 9.5vw, 168px);
    text-transform: uppercase;
    color: var(--color-text);
  }
  .sub__word {
    display: block;
    opacity: 0;
    transform: translateY(40px);
    animation: subUp 0.9s cubic-bezier(.22,1,.36,1) forwards;
  }
  .sub__word:nth-child(1) { animation-delay: 0.05s; }
  .sub__word:nth-child(2) { animation-delay: 0.2s; }
  .sub__word:nth-child(3) { animation-delay: 0.35s; }
  .sub__word--serif {
    font-family: 'Times New Roman', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    letter-spacing: -0.02em;
    line-height: 0.88;
    padding-left: 0.08em;
    color: var(--color-text-soft);
  }
  .sub__word--serif em { font-style: italic; }
  .sub__word--accent { color: var(--color-brand); }
  @keyframes subUp {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .sub__lead {
    max-width: 480px;
    font-size: clamp(15px, 1.2vw, 17px);
    color: var(--color-text-soft);
    line-height: 1.6;
    margin: 0 0 36px;
  }

  /* ─── Форма ─────────────────────────────────────────────────── */
  .sub__form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 14px;
    max-width: 560px;
    margin-bottom: 32px;
    align-items: stretch;
  }

  .sub__field {
    position: relative;
    grid-column: 1 / 2;
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: 0;
    padding: 14px 18px 12px;
    transition: border-color 0.25s ease, background 0.25s ease;
  }
  .sub__field:focus-within {
    border-color: var(--color-brand);
    background: #ffffff;
  }
  .sub__field-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 4px;
  }
  .sub__field input {
    background: transparent;
    border: 0;
    outline: 0;
    font-family: 'Times New Roman', Georgia, serif;
    font-size: 22px;
    color: var(--color-text);
    width: 100%;
    padding: 0;
    line-height: 1.2;
    letter-spacing: -0.005em;
  }
  .sub__field input::placeholder {
    color: var(--color-muted-2);
    font-style: italic;
  }
  /* Мигающий типографский курсор у поля */
  .sub__field-cursor {
    position: absolute;
    right: 18px;
    bottom: 16px;
    width: 2px;
    height: 22px;
    background: var(--color-text);
    animation: subCaret 1s steps(2) infinite;
    opacity: 0.55;
  }
  .sub__field:focus-within .sub__field-cursor { display: none; }
  @keyframes subCaret {
    50% { opacity: 0; }
  }

  /* Кнопка с почтовым штампом */
  .sub__submit {
    position: relative;
    grid-column: 2 / 3;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 18px 24px 18px 26px;
    background: var(--color-text);
    color: var(--color-bg);
    border: 1.5px solid var(--color-text);
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease;
    overflow: visible;
    white-space: nowrap;
  }
  .sub__submit:hover {
    background: var(--color-brand);
    color: #ffffff;
    transform: translateY(-2px);
  }
  .sub__submit:active { transform: translateY(0); }
  .sub__submit-text { position: relative; z-index: 1; }

  .sub__submit-stamp {
    position: absolute;
    top: -22px;
    right: -22px;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--color-brand);
    color: #ffffff;
    display: grid;
    place-items: center;
    transform: rotate(-8deg);
    box-shadow: 0 6px 16px -6px rgba(222,57,34,0.55);
    transition: transform 0.4s cubic-bezier(.22,1,.36,1);
  }
  .sub__submit:hover .sub__submit-stamp {
    transform: rotate(4deg) scale(1.08);
  }
  .sub__stamp-inner {
    position: relative;
    width: 100%; height: 100%;
    display: grid; place-items: center;
  }
  .sub__stamp-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    animation: subStampSpin 14s linear infinite;
    font-family: var(--font-mono);
    font-size: 8.5px;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.85);
  }
  /* Круговой текст по периметру штампа */
  .sub__stamp-ring span {
    position: absolute;
    inset: 0;
    display: block;
    transform-origin: center;
  }
  /* Простой fallback: текст не по кругу, но крутится */
  .sub__stamp-ring > span {
    inset: 0;
    text-align: center;
    line-height: 64px;
    white-space: nowrap;
    transform: scale(0.85);
  }
  @keyframes subStampSpin {
    to { transform: rotate(360deg); }
  }

  .sub__consent {
    grid-column: 1 / -1;
    margin: 6px 0 0;
    font-size: 12px;
    color: var(--color-muted);
    line-height: 1.55;
  }

  /* ─── Каналы ────────────────────────────────────────────────── */
  .sub__channels {
    border-top: 1px solid var(--color-border);
    padding-top: 22px;
  }
  .sub__channels-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 16px;
  }
  .sub__channels-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  .sub__channel {
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  }
  .sub__channel:hover {
    transform: translateY(-2px);
    border-color: var(--color-text);
    background: #ffffff;
  }
  .sub__channel-n {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--color-muted);
  }
  .sub__channel-icon {
    width: 32px; height: 32px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    display: grid; place-items: center;
    color: var(--color-text);
    transition: background 0.25s, color 0.25s;
  }
  .sub__channel:hover .sub__channel-icon {
    background: var(--color-brand);
    color: #ffffff;
    border-color: var(--color-brand);
  }
  .sub__channel-body { display: flex; flex-direction: column; line-height: 1.2; }
  .sub__channel-label {
    font-family: var(--font-display);
    font-size: 16px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-text);
  }
  .sub__channel-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    margin-top: 2px;
  }
  .sub__channel-arrow {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--color-muted);
    transition: transform 0.25s ease, color 0.25s ease;
  }
  .sub__channel:hover .sub__channel-arrow {
    color: var(--color-brand);
    transform: translateX(4px);
  }

  /* ─── Обложка журнала ──────────────────────────────────────── */
  .sub__right {
    position: relative;
    height: 100%;
    min-height: 580px;
    display: grid;
    place-items: center;
  }

  .sub__mag {
    position: relative;
    width: min(380px, 100%);
    aspect-ratio: 3 / 4.2;
    transform: rotate(-3.5deg);
    transition: transform 0.5s cubic-bezier(.22,1,.36,1);
    will-change: transform;
  }
  .sub__mag:hover {
    transform: rotate(-1deg) translateY(-6px);
  }
  /* Обложка */
  .sub__mag-cover {
    position: relative;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, #f6efde 0%, #ede4ce 100%);
    color: var(--color-text);
    padding: 26px 26px 22px;
    box-shadow:
      0 26px 40px -22px rgba(20,18,16,0.45),
      0 6px 16px -8px rgba(20,18,16,0.25),
      inset 0 0 0 1px rgba(20,18,16,0.12);
    display: grid;
    grid-template-rows: auto auto 1fr auto auto;
    gap: 18px;
    overflow: hidden;
  }
  /* Бумажная текстура */
  .sub__mag-paper {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(135deg, rgba(20,18,16,0.025) 0 2px, transparent 2px 6px);
    pointer-events: none;
  }
  /* Корешок журнала */
  .sub__mag-spine {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 14px;
    background: linear-gradient(90deg, rgba(20,18,16,0.18), transparent);
    pointer-events: none;
  }
  .sub__mag-top, .sub__mag-bottom {
    position: relative;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    color: var(--color-text-soft);
    text-transform: uppercase;
  }
  .sub__mag-top { border-bottom: 1px solid rgba(20,18,16,0.18); padding-bottom: 8px; }
  .sub__mag-bottom { border-top: 1px solid rgba(20,18,16,0.18); padding-top: 8px; }

  .sub__mag-brand {
    position: relative;
    display: flex;
    align-items: flex-end;
    gap: 8px;
  }
  .sub__mag-brand-serif {
    font-family: 'Times New Roman', Georgia, serif;
    font-size: 96px;
    line-height: 0.78;
    font-weight: 400;
    color: var(--color-brand);
    margin-bottom: -8px;
  }
  .sub__mag-brand-stack { display: flex; flex-direction: column; gap: 4px; }
  .sub__mag-brand-stack > span:first-child {
    font-family: var(--font-display);
    font-size: 38px;
    letter-spacing: 0.04em;
    color: var(--color-text);
    text-transform: uppercase;
    line-height: 1;
  }
  .sub__mag-brand-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .sub__mag-headline {
    position: relative;
    font-family: 'Times New Roman', Georgia, serif;
    font-style: italic;
    font-size: 22px;
    line-height: 1.25;
    color: var(--color-text);
    border-top: 1px solid rgba(20,18,16,0.18);
    border-bottom: 1px solid rgba(20,18,16,0.18);
    padding: 14px 0;
  }

  .sub__mag-rubrics {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--color-text-soft);
  }

  /* Стикер NEW */
  .sub__sticker {
    position: absolute;
    top: -22px; right: -22px;
    width: 100px; height: 100px;
    border-radius: 50%;
    background: var(--color-brand);
    color: #ffffff;
    display: grid;
    place-items: center;
    transform: rotate(12deg);
    box-shadow: 0 10px 20px -8px rgba(222,57,34,0.55);
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 0.06em;
    text-align: center;
    line-height: 1;
    animation: subSticker 4s ease-in-out infinite;
  }
  .sub__sticker span { display: block; }
  .sub__sticker span:nth-child(2) { font-family: var(--font-mono); font-size: 10px; margin: 4px 0; opacity: 0.85; }
  .sub__sticker span:nth-child(3) { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; opacity: 0.85; }
  @keyframes subSticker {
    0%,100% { transform: rotate(12deg) translateY(0); }
    50%     { transform: rotate(10deg) translateY(-4px); }
  }

  /* Подписи на полях */
  .sub__margin {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    opacity: 0.85;
  }
  .sub__margin--1 { top: 8%;  right: -8%; transform: rotate(8deg); }
  .sub__margin--2 { bottom: 6%; left: -10%; transform: rotate(-6deg); max-width: 200px; }

  /* ─── Адаптив ──────────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .sub__inner { grid-template-columns: 1fr; gap: 56px; }
    .sub__right { min-height: 0; order: -1; }
    .sub__mag { width: min(320px, 80vw); }
    .sub__margin { display: none; }
  }
  @media (max-width: 720px) {
    .sub { padding: 80px 0 80px; }
    .sub__form { grid-template-columns: 1fr; }
    .sub__submit { grid-column: 1 / -1; justify-content: center; }
    .sub__submit-stamp { top: -16px; right: -8px; width: 52px; height: 52px; }
    .sub__channels-list { grid-template-columns: 1fr; }
    .sub__title { font-size: clamp(48px, 14vw, 84px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .sub__word, .sub__eyebrow-dot, .sub__stamp-ring,
    .sub__sticker, .sub__field-cursor {
      animation: none;
    }
    .sub__word { opacity: 1; transform: none; }
  }
</style>

<script>
  // Лёгкий tilt у обложки журнала: при движении мыши над секцией —
  // обложка наклоняется к курсору. Без библиотек.
  const root = document.querySelector('.sub') as HTMLElement | null;
  const mag = document.querySelector<HTMLElement>('[data-mag]');
  if (root && mag && window.matchMedia('(hover: hover)').matches && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let raf = 0;
    let targetX = -3.5, targetY = 0, curX = -3.5, curY = 0;

    root.addEventListener('mousemove', (e) => {
      const rect = root.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      targetX = -3.5 + x * 6;
      targetY = y * -4;
      if (!raf) raf = requestAnimationFrame(tick);
    });
    root.addEventListener('mouseleave', () => {
      targetX = -3.5; targetY = 0;
      if (!raf) raf = requestAnimationFrame(tick);
    });

    function tick() {
      curX += (targetX - curX) * 0.12;
      curY += (targetY - curY) * 0.12;
      mag.style.transform = `rotate(${curX}deg) translateY(${curY}px)`;
      if (Math.abs(targetX - curX) > 0.02 || Math.abs(targetY - curY) > 0.02) {
        raf = requestAnimationFrame(tick);
      } else {
        raf = 0;
      }
    }
  }

  // Имитация отправки формы (для демо — никуда не отправляем).
  const form = document.querySelector<HTMLFormElement>('.sub__form');
  const submit = form?.querySelector<HTMLButtonElement>('.sub__submit');
  const stamp = submit?.querySelector<HTMLElement>('.sub__submit-stamp');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = form.querySelector<HTMLInputElement>('#sub-email');
    if (!input?.value || !submit) return;

    submit.disabled = true;
    submit.querySelector('.sub__submit-text')!.textContent = 'Готово';
    if (stamp) stamp.style.transform = 'rotate(8deg) scale(1.18)';

    setTimeout(() => {
      submit.disabled = false;
      submit.querySelector('.sub__submit-text')!.textContent = 'Подписаться';
      if (stamp) stamp.style.transform = '';
      form.reset();
    }, 2400);
  });
</script>
